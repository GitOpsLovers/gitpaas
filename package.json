{
  "name": "@gitopslovers/artifactory",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "turbo": "2.10.4",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": "26.1.0"
  }
}
