# Production environment for the Artifactory control-plane stack.
#
# Copy this file to `.env` in this directory and fill in real values, then run:
#   docker compose -f iac/production/docker-compose.yml up -d --build
#
# docker compose auto-loads `.env` from this directory both for ${...}
# interpolation in docker-compose.yml AND (via env_file) as the backend's
# runtime configuration. NEVER commit a filled-in `.env`.

# ---- Image build args (pinned to .tool-versions) ----
NODE_VERSION=26.1.0
PNPM_VERSION=11.1.3
IMAGE_TAG=latest

# ---- Host port bindings ----
# Published on the host. With a reverse proxy (Phase 2) these move behind it.
BACKEND_PORT=3000
FRONTEND_PORT=8080

# ---- Backend runtime ----
# NOTE: with NODE_ENV=production the backend disables TypeORM `synchronize`, so
# the database schema must already exist. Until the migrations slice lands there
# is no schema bootstrap here — see the deployment roadmap (Phase 1). To stand up
# a throwaway instance before migrations exist, set NODE_ENV=development so the
# app auto-creates the schema on boot.
NODE_ENV=production
PORT=3000
# Must list the browser origin(s) the frontend is served from (comma-separated).
CORS_ORIGIN=http://localhost:8080
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_STREAM_TTL=60000
THROTTLE_STREAM_LIMIT=1000

# ---- PostgreSQL (both the postgres service and the backend read these) ----
POSTGRES_USER=artifactory
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=artifactory
# Backend -> database. Host is the compose service name.
DB_HOST=postgres
DB_PORT=5432
DB_USER=artifactory
DB_PASSWORD=change-me-in-production
DB_NAME=artifactory

# ---- Redis (live deployment-log buffer + pub/sub) ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- GitHub App (source integration) ----
GITHUB_APP_ID=
# Base64-encoded PEM private key (the app decodes it at runtime).
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# ---- Remote Docker daemon over mTLS (the VPS that runs deployed apps) ----
VPS_DOCKER_HOST=
VPS_DOCKER_PORT=2376
# Path INSIDE the backend container where ca.pem/cert.pem/key.pem are mounted.
VPS_DOCKER_CERT_PATH=/certs
# Path ON THE HOST holding those client certs (mounted read-only into the app).
VPS_CERT_HOST_PATH=./certs

# ---- JWT ----
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
